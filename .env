NODE_ENV=production
PORT=3000
TRUST_PROXY=true
SERVE_STATIC=true
UPLOAD_DIR=uploads

# Frontend/API URL strategy
# Keep empty for same-domain deployment via ALB endpoint
FRONTEND_BASE_URL=
API_BASE_URL=
ASSET_BASE_URL=

# CORS
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://crackers-prod-alb-1907787511.ap-southeast-1.elb.amazonaws.com,https://crackers-prod-alb-1907787511.ap-southeast-1.elb.amazonaws.com

# Auth cookie
AUTH_COOKIE_NAME=authToken
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SAME_SITE=lax
# Set to true only when you always access site via HTTPS
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_MAX_AGE_MS=3600000

# Database (RDS)
DATABASE_URL=
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_HOST=crackers-prod-db.c7cqc8ey69kg.ap-southeast-1.rds.amazonaws.com
DB_PORT=5432
DB_DATABASE=crackersdb
DB_USER=postgres
DB_PASSWORD=12345678

JWT_SECRET=DevaSuperSecureKey@123

# Storage (S3)
STORAGE_DRIVER=s3
S3_REGION=ap-south-1
S3_BUCKET_NAME=crackers-prod-assets
S3_UPLOAD_PREFIX=uploads
S3_PUBLIC_BASE_URL=
S3_UPLOAD_ACL=

# Optional Secrets Manager (disabled by default)
AWS_REGION=ap-south-1
AWS_SECRETS_ENABLED=false
AWS_SECRETS_REQUIRED=false
AWS_SECRET_ID=
AWS_SECRETS_REGION=
