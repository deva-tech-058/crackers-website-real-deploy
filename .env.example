NODE_ENV=development
PORT=3000
TRUST_PROXY=false
SERVE_STATIC=true
UPLOAD_DIR=uploads
UPLOAD_FILE_MAX_MB=1024
# NOTE: If uploads still fail with HTTP 413, increase Nginx `client_max_body_size`
# and reload Nginx. App limit alone is not enough.

# Frontend/API URL strategy
# Leave empty when using same domain path routing (/api and /uploads)
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
ASSET_BASE_URL=http://localhost:3000

# CORS
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth cookie
AUTH_COOKIE_NAME=authToken
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_MAX_AGE_MS=3600000

# Database (RDS/Local)
# Preferred in production:
DATABASE_URL=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Storage (Local uploads or S3)
STORAGE_DRIVER=local
S3_REGION=
S3_BUCKET_NAME=
S3_UPLOAD_PREFIX=uploads
S3_PUBLIC_BASE_URL=
S3_UPLOAD_ACL=

# Fallback individual DB values (used if DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=crackers_db
DB_USER=postgres
DB_PASSWORD=change_me

JWT_SECRET=replace_with_strong_secret

# Optional: AWS Secrets Manager (disabled unless explicitly enabled)
AWS_REGION=
AWS_SECRETS_ENABLED=false
AWS_SECRETS_REQUIRED=false
AWS_SECRET_ID=
AWS_SECRETS_REGION=
